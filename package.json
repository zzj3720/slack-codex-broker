{
  "name": "slack-codex-broker",
  "version": "0.1.0",
  "description": "Slack Socket Mode broker that routes Slack threads into Codex app-server sessions with isolated workspaces.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zzj3720/slack-codex-broker.git"
  },
  "bugs": {
    "url": "https://github.com/zzj3720/slack-codex-broker/issues"
  },
  "homepage": "https://github.com/zzj3720/slack-codex-broker#readme",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build/copy-static-assets.mjs",
    "dev": "tsx watch src/index.ts",
    "dev:admin": "tsx watch src/admin-index.ts",
    "dev:worker": "tsx watch src/worker-index.ts",
    "ops:check:real": "node scripts/ops/check-real.mjs",
    "ops:auth:real": "node scripts/ops/auth-real.mjs",
    "ops:auth:profiles": "node scripts/ops/auth-profiles.mjs",
    "ops:ui:real": "node scripts/ops/auth-ui-real.mjs",
    "ops:rollout:real": "node scripts/ops/rollout-real.mjs",
    "ops:status:real": "node scripts/ops/status-real.mjs",
    "ops:macos:bootstrap": "node scripts/ops/macos-bootstrap.mjs",
    "start": "node dist/src/index.js",
    "start:admin": "node dist/src/admin-index.js",
    "start:worker": "node dist/src/worker-index.js",
    "test": "vitest run",
    "test:e2e:mock": "tsx test/manual/run-mock-e2e.ts",
    "manual:test": "tsx test/manual/run-real-codex-smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
